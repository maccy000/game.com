<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>2分の1チャレンジ</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      background: #f0f4f8;
      padding: 50px;
    }

    h1 {
      color: #333;
    }

    .card {
      background: white;
      padding: 30px;
      border-radius: 15px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
      display: inline-block;
    }

    button {
      padding: 10px 20px;
      font-size: 16px;
      border: none;
      border-radius: 8px;
      background: #4CAF50;
      color: white;
      cursor: pointer;
      margin-top: 20px;
    }

    button:hover {
      background: #45a049;
    }

    .result {
      margin-top: 20px;
      font-size: 18px;
    }

    .prob {
      margin-top: 10px;
      font-weight: bold;
      color: #0077cc;
    }
  </style>
</head>
<body>

  <h1>2分の1チャレンジゲーム</h1>

  <div class="card">
    <p>ボタンを押すたびに「1/2」を引けるか挑戦！</p>
    <p>外れたらゲームオーバー！</p>

    <button onclick="playGame()">挑戦する</button>

    <div class="result" id="result">成功回数: 0</div>
    <div class="prob" id="probability">確率: 100%</div>
  </div>

  <script>
    let successCount = 0;
    let gameOver = false;

    function playGame() {
      if (gameOver) {
        // リセット
        successCount = 0;
        gameOver = false;
        document.getElementById("result").textContent = "成功回数: 0";
        document.getElementById("probability").textContent = "確率: 100%";
        return;
      }

      // 0か1（50%）
      let random = Math.random();

      if (random < 0.5) {
        // 成功
        successCount++;
        updateDisplay();
      } else {
        // 失敗
        gameOver = true;
        updateDisplay(true);
      }
    }

    function updateDisplay(isGameOver = false) {
      document.getElementById("result").textContent = "成功回数: " + successCount;

      // 確率 = (1/2)^n
      let probability = Math.pow(0.5, successCount);
      let percent = (probability * 100).toFixed(6);

      document.getElementById("probability").textContent =
        "ここまで成功し続ける確率: " + percent + "%";

      if (isGameOver) {
        document.getElementById("result").textContent += "（ゲームオーバー！もう一度押すとリセット）";
      }
    }
  </script>

</body>
</html>
